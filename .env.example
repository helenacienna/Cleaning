DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cienna_cleaning"
OPS_API_TOKEN="set-a-random-secret-for-cron-calls"
NOTIFICATION_DISPATCH_ENABLED="false"
NOTIFICATION_CHANNEL="telegram"
NOTIFICATION_TARGET="your-telegram-chat-id"
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TASK_PHOTO_DIR="./storage/task-photos"
GOOGLE_CALENDAR_SHIFT_RUNS_ID="your-calendar-id@group.calendar.google.com"
SHIFT_RUN_SYNC_DRY_RUN="true"
SHIFT_RUN_SYNC_DAYS_PAST="7"
SHIFT_RUN_SYNC_DAYS_FUTURE="21"
SHIFT_RUN_SYNC_TIME_ZONE="Australia/Brisbane"
SHIFT_RUN_SYNC_STATE_PATH="./data/google-calendar-sync/shift-runs-state.json"
SHIFT_RUN_SYNC_ALLOW_BOOTSTRAP="false"
GOOGLE_SERVICE_ACCOUNT_JSON_PATH="/absolute/path/to/google-service-account.json"
# Or set GOOGLE_SERVICE_ACCOUNT_JSON to the full JSON string instead.
